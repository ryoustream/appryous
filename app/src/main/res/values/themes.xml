<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- Base app theme — dark by default (streaming app) -->
    <style name="Theme.AppRyous" parent="Theme.Material3.Dark.NoActionBar">
        <item name="colorPrimary">@color/accent_purple</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">@color/accent_purple</item>
        <item name="colorOnSecondary">@color/white</item>
        <item name="colorSurface">@color/surface</item>
        <item name="colorOnSurface">@color/on_surface</item>
        <item name="colorOnBackground">@color/on_surface</item>
        <item name="colorError">@color/error</item>
        <item name="android:colorBackground">@color/background</item>
        <item name="android:windowBackground">@color/background</item>
        <!-- Status bar dan navigation bar transparan untuk edge-to-edge -->
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:windowLightNavigationBar">false</item>
        <!-- Transition -->
        <item name="android:windowContentTransitions">true</item>
        <item name="android:windowAllowEnterTransitionOverlap">true</item>
        <item name="android:windowAllowReturnTransitionOverlap">true</item>
    </style>

    <!-- Splash screen -->
    <style name="Theme.AppRyous.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/background</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_splash_logo</item>
        <item name="windowSplashScreenAnimationDuration">800</item>
        <item name="postSplashScreenTheme">@style/Theme.AppRyous</item>
    </style>

    <!-- Player theme — fullscreen, no status bar -->
    <style name="Theme.AppRyous.Player" parent="Theme.AppRyous">
        <item name="android:windowFullscreen">false</item>
        <item name="android:windowLayoutInDisplayCutoutMode">shortEdges</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
    </style>

    <!-- BottomSheet style -->
    <style name="Theme.AppRyous.BottomSheet" parent="Theme.Material3.Dark.BottomSheetDialog">
        <item name="bottomSheetStyle">@style/Widget.AppRyous.BottomSheet</item>
    </style>

    <style name="Widget.AppRyous.BottomSheet" parent="Widget.Material3.BottomSheet">
        <item name="android:background">@color/surface_variant</item>
        <item name="shapeAppearanceOverlay">@style/ShapeAppearance.AppRyous.BottomSheet</item>
    </style>

    <style name="ShapeAppearance.AppRyous.BottomSheet" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSizeTopLeft">16dp</item>
        <item name="cornerSizeTopRight">16dp</item>
        <item name="cornerSizeBottomLeft">0dp</item>
        <item name="cornerSizeBottomRight">0dp</item>
    </style>

    <!-- Chip style -->
    <style name="Widget.AppRyous.Chip" parent="Widget.Material3.Chip.Filter">
        <item name="android:textColor">@color/chip_text_color</item>
    </style>

    <!-- Card style -->
    <style name="Widget.AppRyous.Card" parent="Widget.Material3.CardView.Elevated">
        <item name="cardBackgroundColor">@color/surface_variant</item>
        <item name="cardCornerRadius">8dp</item>
        <item name="cardElevation">0dp</item>
    </style>

    <!-- TextAppearance overrides -->
    <style name="TextAppearance.AppRyous.Title" parent="TextAppearance.Material3.TitleMedium">
        <item name="android:textColor">@color/on_surface</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>

    <style name="TextAppearance.AppRyous.Caption" parent="TextAppearance.Material3.BodySmall">
        <item name="android:textColor">@color/on_surface_variant</item>
    </style>

</resources>
