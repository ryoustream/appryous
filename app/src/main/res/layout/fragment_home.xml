<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <androidx.swiperefreshlayout.widget.SwipeRefreshLayout
        android:id="@+id/swipe_refresh"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <androidx.core.widget.NestedScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- Hero ViewPager2 -->
                <androidx.viewpager2.widget.ViewPager2
                    android:id="@+id/vp_hero"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/hero_height"/>

                <!-- Hero indicator dots -->
                <com.google.android.material.tabs.TabLayout
                    android:id="@+id/hero_indicator"
                    android:layout_width="wrap_content"
                    android:layout_height="16dp"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginTop="-20dp"
                    app:tabBackground="@drawable/hero_indicator_selector"
                    app:tabGravity="center"
                    app:tabIndicatorHeight="0dp"
                    app:tabPaddingStart="4dp"
                    app:tabPaddingEnd="4dp"/>

                <!-- Scanning banner -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/card_scanning"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="16dp"
                    android:layout_marginTop="16dp"
                    android:visibility="gone"
                    app:cardBackgroundColor="@color/surface_variant"
                    app:cardCornerRadius="8dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:padding="12dp"
                        android:text="@string/home_scanning"
                        android:textColor="@color/on_surface_variant"
                        android:textSize="13sp"
                        android:drawableStart="@drawable/ic_sync"
                        android:drawablePadding="8dp"/>
                </com.google.android.material.card.MaterialCardView>

                <!-- Continue Watching section -->
                <LinearLayout
                    android:id="@+id/section_continue"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="gone">

                    <include layout="@layout/component_section_header"
                        android:id="@+id/header_continue"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"/>

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/rv_continue"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:paddingHorizontal="12dp"
                        android:clipToPadding="false"
                        android:orientation="horizontal"/>
                </LinearLayout>

                <!-- Series section -->
                <LinearLayout
                    android:id="@+id/section_series"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <include layout="@layout/component_section_header"
                        android:id="@+id/header_series"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"/>

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/rv_series"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:paddingHorizontal="12dp"
                        android:clipToPadding="false"
                        android:orientation="horizontal"/>
                </LinearLayout>

                <!-- Movies section -->
                <LinearLayout
                    android:id="@+id/section_movies"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingBottom="80dp">

                    <include layout="@layout/component_section_header"
                        android:id="@+id/header_movies"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"/>

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/rv_movies"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:paddingHorizontal="12dp"
                        android:clipToPadding="false"
                        android:orientation="horizontal"/>
                </LinearLayout>

            </LinearLayout>
        </androidx.core.widget.NestedScrollView>
    </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
