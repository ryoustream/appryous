<?xml version="1.0" encoding="utf-8"?>
<!--
    Android API 31+ backup rules.
    Hanya backup settings dan history.
    Posisi & lib cache TIDAK di-backup (data sementara).
-->
<data-extraction-rules>
    <cloud-backup>
        <include domain="sharedpref" path="rs_settings.xml"/>
        <include domain="sharedpref" path="rs_watch_history.xml"/>
    </cloud-backup>
    <device-transfer>
        <include domain="sharedpref" path="rs_settings.xml"/>
        <include domain="sharedpref" path="rs_watch_history.xml"/>
        <include domain="sharedpref" path="rs_positions.xml"/>
    </device-transfer>
</data-extraction-rules>
